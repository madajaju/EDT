<%- include(`${baseDir}/${lang.id}/header.html`, { ...locals }) %>

<main id="content" class="brief-editorial">

    <!-- Breadcrumbs -->
    <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol>
            <li><a href="<%= lang.id %>/home/index.html">Home</a></li>
            <li><a href="<%= lang.id %>/briefs/index.html">Embracing Digital This Week</a></li>
            <li aria-current="page"><%= brief.date %></li>
        </ol>
    </nav>

    <!-- HERO -->
    <section class="brief-hero">
        <div class="brief-hero-main">
            <h1>
                <%= lang.newsTitle %>
                <span class="brief-date">— <%= brief.date %></span>
            </h1>

            <!-- At a glance / summary -->
            <div class="brief-glance">
                <% if (summary) { %>
                    <%- summary %>
                <% } else { %>
                    <p>
                        <%= lang.convoSummary %>
                    </p>
                <% } %>
            </div>

            <!-- CTAs -->
            <div class="brief-ctas">
                <% if (brief.watch) { %>
                    <a class="listen-now" href="<%= brief.watch %>" target="_blank" rel="noopener">
                        <%- lang.watchNow %>
                    </a>
                <% } %>
                <% if (brief.listen) { %>
                    <a class="listen-now" href="<%= brief.listen %>" target="_blank" rel="noopener">
                        <%- lang.listenNow %>
                    </a>
                <% } %>
                <a class="listen-now" href="<%= lang.id %>/newsletter.html"><%- lang.subscribe %></a>
                <a class="listen-now" href="<%= lang.id %>/community.html"><%- lang.community %></a>
            </div>
            <!-- Chips: prefer explicit tags, otherwise pillar anchors -->
            <% if (brief.tags?.length) { %>
                <nav class="pillar-chips" aria-label="Pillars covered this week">
                    <% brief.tags.forEach(tag => { %>
                        <a href="<%= lang.id %>/search.html?query=<%= encodeURIComponent(tag) %>"><%= tag %></a>
                    <% }) %>
                </nav>
            <% } else if (pillars && Object.keys(pillars).length) { %>
                <nav class="pillar-chips" aria-label="Jump to coverage by pillar">
                    <% Object.keys(pillars).forEach(function (pillarName) { %>
                        <a href="#<%= pillarName.toLowerCase().replace(/\s+/g,'-') %>"><%= pillarName %></a>
                    <% }) %>
                </nav>
            <% } %>
        </div>
        <div class="brief-hero-side" aria-label="Episode media">
            <% if (brief.watch || brief.listen) { %>
                <div class="media-item media-video" aria-label="Episode media">
                    <% if (brief.watch) { %>
                        <div class="video-embed">
                            <% let items = brief.watch.split('/'); %>

                            <iframe width="560" height="315"
                                    src="https://www.youtube.com/embed/<%- items[items.length-1]%>"
                                    title="YouTube video player" frameborder="0"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                    referrerpolicy="strict-origin-when-cross-origin" allowfullscreen>
                            </iframe>
                        </div>
                </div>
                <% } %>

                <% if (brief.listen) { %>
                    <div class="media-item media-audio">
                        <div class="audio-embed">
                            <% let items = brief.listen.split('/'); %>
                            <iframe
                                    width="100%"
                                    height="180"
                                    frameborder="0"
                                    scrolling="no"
                                    src="https://share.transistor.fm/e/<%- items[items.length-1]%>"
                                    title="Embracing Digital This Week audio"
                                    loading="lazy"
                            ></iframe>

                        </div>
                        <!-- brief.listen_embed can be the HTML Transistor.fm gives you -->
                        <%- brief.listen_embed %>
                    </div>
                <% } %>
        </div>
        <% } %>
        </div>
    </section>

    <!-- TOP STORIES -->
    <% if (topStories?.length) { %>
        <section class="brief-top-stories">
            <h2><%- lang.topStories %></h2>

            <% topStories.forEach(story => {
                const hasTitle = story.title && story.title.trim().length;
                let fallbackTitle = '';
                if (!hasTitle && story.text) {
                    // strip basic HTML tags if any and trim for fallback
                    const plain = String(story.text).replace(/<[^>]+>/g, '').trim();
                    fallbackTitle = plain.length > 80 ? plain.slice(0, 80) + '…' : plain;
                }
                const displayTitle = hasTitle ? story.title : fallbackTitle;
            %>
            <article class="top-story">
                <% if (story.image) { %>
                    <img src="<%= story.image %>"
                         alt="<%- displayTitle || 'Story image' %>"
                         loading="lazy">
                <% } else { %>
                    <img src="/images/logo.png"
                         alt="Embracing Digital Transformation Placeholder"
                         class="fallback-image"
                         loading="lazy">
                <% } %>

                <div class="top-story-content">
                    <% if (displayTitle) { %>
                        <h3><%- displayTitle %></h3>
                    <% } %>

                    <% if (story.text) { %>
                        <p><%- story.text %></p>
                    <% } %>

                    <% if (story.urls?.length) { %>
                        <div class="story-links">
                            <% story.urls.forEach(l => { %>
                                <a href="<%= l.url %>" target="_blank" rel="noopener">
                                    <%= l.label || lang.readMore %>
                                </a>
                            <% }) %>
                        </div>
                    <% } %>

                    <% if (story.pillar) { %>
                        <span class="story-pillar"><%= story.pillar %></span>
                    <% } %>
                </div>
            </article>
            <% }) %>
        </section>
    <% } %>

    <!-- FULL COVERAGE BY PILLAR -->
    <section class="brief-pillars">
        <h2><%- lang.fullCoverage %></h2>

        <% for (let pillarName in pillars) {
            const pillar = pillars[pillarName];
            if (!pillar || !pillar.articles || !pillar.articles.length) continue;
        %>
        <section class="pillar-section" id="<%= pillarName.toLowerCase().replace(/\s+/g,'-') %>">
            <h3><%= pillarName %></h3>

            <% pillar.articles.forEach(article => {
                const hasTitle = article.title && article.title.trim().length;
                let fallbackTitle = '';
                if (!hasTitle && article.text) {
                    const plain = String(article.text).replace(/<[^>]+>/g, '').trim();
                    fallbackTitle = plain.length > 80 ? plain.slice(0, 80) + '…' : plain;
                }
                const displayTitle = hasTitle ? article.title : fallbackTitle;
            %>
            <article class="pillar-article">
                <div class="pillar-article-image">
                    <% if (article.image) { %>
                        <img src="<%= article.image %>"
                             alt="<%- displayTitle || (pillarName + ' story image') %>"
                             loading="lazy">
                    <% } else { %>
                        <img src="/images/logo.png"
                             alt="Embracing Digital Transformation Placeholder"
                             class="fallback-image"
                             loading="lazy">
                    <% } %>
                </div>

                <div class="pillar-article-content">
                    <% if (displayTitle) { %>
                        <h4><%- displayTitle %></h4>
                    <% } %>

                    <% if (article.text) { %>
                        <p><%- article.text %></p>
                    <% } %>

                    <% if (article.urls?.length) { %>
                        <div class="story-links">
                            <% article.urls.forEach(l => { %>
                                <a href="<%= l.url %>" target="_blank" rel="noopener">
                                    <%= l.label ||  lang.readMore %>
                                </a>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
            </article>
            <% }) %>
        </section>
        <% } %>
    </section>
</main>

<%- include(`${baseDir}/${lang.id}/footer.html`, { ...locals }) %>
