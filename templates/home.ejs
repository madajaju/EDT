<%- include(`${baseDir}/${lang.id}/header.html`, {
...locals,
page: {
...(page || {}),
id: 'home',
title: (page && page.title) || 'Embracing Digital | Weekly Guidance for Digital Transformation Leaders',
description: (page && page.description) || 'Weekly briefings, frameworks, interviews, and architectural analysis to help leaders navigate digital transformation.',
canonical: (page && page.canonical) || `https://embracingdigital.org/${lang.id}/home/`,
ogImage: (page && page.ogImage) || 'https://embracingdigital.org/images/logo.png'
}
}) %>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        populateContent();
    });
    window.contentData = <%- contentData %>;
</script>

<main id="content">

    <%
    // Helper functions for summary formatting and safe string processing
    const esc = s => String(s ?? '');
    const stripHtml = s => esc(s).replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
    const truncate = (s, n=220) => {
        const t = stripHtml(s);
        if (t.length <= n) return t;
        return t.slice(0, n).replace(/\s+\S*$/, '') + '…';
    };

    // Normalize content item for display
    const normalize = x => {
        if (!x) return null;

        const guestsText = Array.isArray(x.guests) && x.guests.length
                ? x.guests.map(g => (g && g.name) ? g.name : String(g)).join(', ')
                : '';

        const read = x.slug || x.read || x.page || x.url || '';

        return {
            title: x.title || x.name || '',
            date: x.date || '',
            summary: x.summary || x.description || '',
            shortSummary: truncate(x.summary || x.description || '', 220),
            url: x.url || '',
            image: x.image || '/images/logo.png',
            watch: x.watch || x.video || '',
            listen: x.listen || x.audio || '',
            read,
            guestsText
        };
    };
    %>

    <!-- Page intro -->
    <section id="hero">
        <h1 class="section-title">This Week on Embracing Digital</h1>
        <p class="hero-subtitle">
            Weekly arc:<br>What changed → How others did it → How to think → How others did it → What to do next.
        </p>
    </section>

    <section class="transformation-container">
        <p>Click on the day to see a preview</p>
        <div class="week-grid" role="tablist" aria-label="Weekly guidance">
            <% /* Placeholder buttons - will be updated dynamically */ %>
            <% ['mon','tues','wed','thu','fri'].forEach((key, idx) => { %>
                <button
                        type="button"
                        class="week-card"
                        role="tab"
                        aria-selected="false"
                        aria-controls="week-details"
                        data-idx="<%= idx %>"
                        data-key="<%= key %>"
                        disabled // will be enabled if content loaded
                >
                <div class="week-card-top">
                    <div class="week-badge">
                        <span class="week-day"><%= key.charAt(0).toUpperCase() + key.slice(1) %></span>
                        <span class="week-intent"></span> <!-- will be filled -->
                    </div>
                    <div class="week-show"></div> <!-- will be filled -->
                </div>

                <img class="week-image" src="">
                <div class="week-card-body">
                    <div class="week-title"><a href="">Loading...</a></div>
                    <div class="week-summary"></div>
                </div>
                </button>
            <% }) %>
        </div>

        <div id="week-details" class="week-details" role="tabpanel" aria-live="polite">
            <div class="week-details-inner">
                <div class="week-details-media">
                    <img id="wd-image" class="week-details-image" src="/images/logo.png" alt="">
                </div>
                <div class="week-details-content">
                    <h3 id="wd-title" class="week-details-title">Select a day</h3>
                    <div id="wd-meta" class="week-details-meta"></div>
                    <p id="wd-summary" class="week-details-summary"></p>
                    <div id="wd-links" class="week-details-links"></div>
                    <div id="wd-guests-wrap" class="week-details-guests" style="display:none;">
                        <strong>Guests:</strong> <span id="wd-guests"></span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script>
        // Helpers - mirroring server-side normalize (for safety)
        function truncate(s, n=220) {
            if (!s) return '';
            const tmp = s.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
            return tmp.length <= n ? tmp : tmp.slice(0, n).replace(/\s+\S*$/, '') + '…';
        }

        function normalize(item) {
            if (!item) return null;
            return {
                title: item.title || item.name || '',
                date: item.date || '',
                summary: item.summary || item.description || '',
                shortSummary: truncate(item.summary || item.description || '', 220),
                url: item.url || '',
                image: item.image || '/images/logo.png',
                watch: item.watch || item.video || '',
                listen: item.listen || item.audio || '',
                read: item.slug || item.read || item.page || item.url || '',
                guestsText: Array.isArray(item.guests) && item.guests.length
                    ? item.guests.map(g => g?.name || String(g)).join(', ')
                    : ''
            };
        }

        // Defines content types in order for days Mon-Fri
        const slotConfig = [
            { key: 'mon', name: 'Embracing Digital This Week', intent: 'What changed', type: 'briefs', index: 0 },
            { key: 'tues', name: 'Embracing Digital Transformation', intent: 'How others did it', type: 'episodes', index: 0 },
            { key: 'wed', name: 'Digital Transformation Architect', intent: 'How to think', type: 'lectures', index: 0 },
            { key: 'thu', name: 'Embracing Digital Transformation', intent: 'How others did it', type: 'episodes', index: 1 },
            { key: 'fri', name: 'Digital Deep Dive', intent: 'What to do next', type: 'deepdives', index: 0 },
        ];

        // Picks latest content ≤ today for the given type
        function getLatestReleased(contentArray) {
            const today = new Date();
            if (!Array.isArray(contentArray)) return [];
            const filtered = contentArray.filter(c => new Date(c.releaseDate) <= today);
            if (!filtered.length) return [];
            filtered.sort((a, b) => new Date(b.releaseDate) - new Date(a.releaseDate));
            return filtered;
        }

        // Populate the UI buttons & details dynamically
        function populateContent() {
            if (!window.contentData) return;

            const cards = Array.from(document.querySelectorAll('.week-card'));
            const details = {
                titleEl: document.getElementById('wd-title'),
                metaEl: document.getElementById('wd-meta'),
                summaryEl: document.getElementById('wd-summary'),
                imgEl: document.getElementById('wd-image'),
                linksEl: document.getElementById('wd-links'),
                guestsWrap: document.getElementById('wd-guests-wrap'),
                guestsEl: document.getElementById('wd-guests'),
            };

            // Build normalized data per slot
            const slotItems = slotConfig.map((slot) => {
                const contentList = window.contentData[slot.type];
                const released = getLatestReleased(contentList);
                const raw = (released && released[slot.index]) ? released[slot.index] : null;
                return {
                    ...slot,
                    raw,
                    data: raw ? normalize(raw) : {
                        title: 'Coming soon',
                        shortSummary: 'No published item available for this slot yet.',
                        image: '/images/logo.png'
                    },
                    disabled: !raw
                };
            });

            // Update buttons UI and enable if content exists
            slotItems.forEach((item, i) => {
                const card = cards[i];
                card.disabled = item.disabled;
                card.setAttribute('aria-disabled', item.disabled ? 'true' : 'false');

                card.querySelector('.week-day').textContent = item.key.charAt(0).toUpperCase() + item.key.slice(1);
                card.querySelector('.week-intent').textContent = item.intent;
                card.querySelector('.week-show').textContent = item.name;

                if (item.data) {
                    card.querySelector('.week-image').src = item.data.image;
                    card.querySelector('.week-image').alt = item.data.title || item.name;
                    card.querySelector('.week-title a').textContent = item.data.title || item.name;
                    card.querySelector('.week-title a').href = item.data.read;
                    card.querySelector('.week-summary').textContent = item.data.shortSummary;
                } else {
                    card.querySelector('.week-image').src = item.data.image;
                    card.querySelector('.week-image').alt = item.data.title || item.name;
                    card.querySelector('.week-title').textContent = item.data.title || 'Coming soon';
                    card.querySelector('.week-summary').textContent = item.data.shortSummary || 'No published item available for this slot yet.';
                }
            });

            // Selection handling (same as your original code)
            function setSelected(idx){
                cards.forEach((c,i) => {
                    const selected = i === idx;
                    c.classList.toggle('is-selected', selected);
                    c.setAttribute('aria-selected', selected ? 'true' : 'false');
                });

                const item = slotItems[idx];
                const d = item?.data;

                if (!d) {
                    details.titleEl.textContent = 'Coming soon';
                    details.metaEl.textContent = '';
                    details.summaryEl.textContent = '';
                    details.imgEl.src = '/images/logo.png';
                    details.imgEl.alt = '';
                    details.linksEl.innerHTML = '';
                    details.guestsWrap.style.display = 'none';
                    return;
                }

                details.titleEl.textContent = d.title || item.name || '';
                details.metaEl.textContent = [item.name, item.key.charAt(0).toUpperCase() + item.key.slice(1), d.date]
                    .filter(Boolean).join(' • ');
                details.summaryEl.innerHTML = d.summary || '';
                details.imgEl.src = d.image || '/images/logo.png';
                details.imgEl.alt = d.title || item.name || '';

                const links = [];
                if (d.read)  links.push(`<a class="listen-now" href="${d.read}">Read</a>`);
                if (d.watch) links.push(`<a class="listen-now" href="${d.watch}" target="_blank" rel="noopener">Watch</a>`);
                if (d.listen)links.push(`<a class="listen-now" href="${d.listen}" target="_blank" rel="noopener">Listen</a>`);
                details.linksEl.innerHTML = links.join(' ');

                if (d.guestsText) {
                    details.guestsEl.textContent = d.guestsText;
                    details.guestsWrap.style.display = '';
                } else {
                    details.guestsWrap.style.display = 'none';
                }
            }

            cards.forEach(card => {
                card.addEventListener('click', () => {
                    const idx = Number(card.getAttribute('data-idx'));
                    if (Number.isFinite(idx)) setSelected(idx);
                });
            });

            // Auto select based on visitor day (Mon - Fri)
            function autoIndex(){
                const dow = new Date().getDay(); // 0=Sun ... 6=Sat
                if (dow >= 1 && dow <= 4) return dow - 1; // Mon->0..Thu->3
                return 0;
            }

                let idx = autoIndex();
                if (cards[idx] && cards[idx].disabled) {
                    const firstEnabled = cards.findIndex(c => !c.disabled);
                    idx = firstEnabled >= 0 ? firstEnabled : 0;
                }
                setSelected(idx);
            }
        </script>
    </section>

    <!-- EXPLORE -->
    <section class="transformation-container" style="background:#f8fafc; color:#000000;">
        <h2 class="section-title" style="color:#000000;">Explore the Transformation Ecosystem</h2>

        <div class="pillar-domain-grid">
            <article class="grid-box">
                <h3>Weekly Briefings</h3>
                <p>Cut through the noise with curated insights across our six pillars. Understand what changed this week and exactly why it matters to your strategy.</p>
                <a class="listen-now" href="/<%= lang.id %>/briefs/index.html">Read Briefings</a>
            </article>

            <article class="grid-box">
                <h3>The DTA Framework</h3>
                <p>Move beyond theory with the Digital Transformation Architect (DTA) lectures. Master the ODXA domains using proven patterns and playbooks.</p>
                <a class="listen-now" href="/<%= lang.id %>/lectures/index.html">Start Learning</a>
            </article>

            <article class="grid-box">
                <h3>Executive Interviews</h3>
                <p>Learn from those leading the charge. Real-world case studies and conversations with industry experts executing transformation at scale.</p>
                <a class="listen-now" href="/<%= lang.id %>/episodes/index.html">Watch Interviews</a>
            </article>

            <article class="grid-box">
                <h3>Digital Deep Dives</h3>
                <p>Turn strategy into action. Practical, technical deep dives designed to provide clear guidance on "what to do next" for your architecture.</p>
                <a class="listen-now" href="/<%= lang.id %>/briefs/deepdives.html">Dive Deeper</a>
            </article>
        </div>
    </section>

    <!-- COMMUNITY / CONVERSION -->
    <section class="transformation-container">
        <h2 class="section-title">Engage & Support</h2>

        <div class="grid-container">
            <article class="grid-box" style="text-align:center;">
                <h3>The Weekly Recap</h3>
                <p>Never miss a signal. Join thousands of digital leaders who receive our weekly recap of briefings, interviews, and guidance directly in their inbox.</p>
                <a class="listen-now" href="/<%= lang.id %>/newsletter.html">Stay Informed</a>
            </article>

            <article class="grid-box" style="text-align:center;">
                <h3>Collaborative Community</h3>
                <p>Transformation doesn’t happen in a vacuum. Connect with a global network of practitioners to share insights, ask questions, and solve complex challenges together.</p>
                <a class="listen-now" href="/<%= lang.id %>/community.html">Join the Discussion</a>
            </article>

            <article class="grid-box" style="text-align:center;">
                <h3>Insider Membership</h3>
                <p>Unlock deeper access. Support the show and get early access to briefings, private Q&amp;A sessions, and exclusive architectural deep dives via Patreon.</p>
                <a class="listen-now" href="https://www.patreon.com/embracingdigital" target="_blank" rel="noopener">Become a Member</a>
            </article>
        </div>
    </section>

    <!-- Structured data: ItemList of featured content -->
    <script type="application/ld+json">
        {
          "@context":"https://schema.org",
          "@type":"WebPage",
          "name":"Embracing Digital Home",
          "url":"https://embracingdigital.org/<%= lang.id %>/home/",
      "about":[
        "Digital transformation",
        "Artificial intelligence",
        "Cybersecurity",
        "Edge computing",
        "Data management",
        "Advanced communications"
      ],
    }
    </script>

    <!-- The rest of your static content below remains as is (Explore, Community, Structured Data) -->

</main>

<%- include(`${baseDir}/${lang.id}/footer.html`, { ...locals }) %>